#!/usr/bin/env bash
# Turnix docs metadata pre-commit hook (hardened, docs/ only, auto DOC_ID+DOC_FILE, repo-local Python)
#
# Scope:
# - Only staged files under docs/** with .md/.txt/.json5
#
# Requires:
# - Git
# - Repo-local embeddable Python at ./python-embedded/python.exe
#
# Guarantees for each targeted staged file:
# - Document MUST end with exactly one metadata block, which is one of:
#
#   doc-meta footer:
#     --- doc-meta ---
#     DOC_ID: <canonical document identifier>
#     DOC_FILE: <canonical repository path>
#     DOC_REV: <revision count>
#     DOC_GIT: <short commit id>
#     ----------------
#
#   bootstrap-meta footer:
#     --- bootstrap-meta ---
#     DOC_ID: <basename without extension>
#     DOC_FILE: <canonical repository path>
#     DOC_REV: <revision count>
#     DOC_GIT: <short commit id>
#     DOC_STATUS: <status>
#     ----------------------
#
#   file-meta footer:
#     --- file-meta ---
#     DOC_ID: <basename without extension>
#     DOC_FILE: <canonical repository path>
#     DOC_REV: <revision count>
#     DOC_GIT: <short commit id>
#     DOC_STATUS: <status>
#     -----------------
#
# - DOC_ID rules:
#   - doc-meta:
#     - derived from filename: "<DOC_ID>_<normalized text>.<EXT>"
#     - DOC_ID pattern:
#       - starts with one or more [A-Z]
#       - may contain additional "-[A-Z]+" segments
#       - ends with "-[A-Z0-9]+"
#       - examples: DD-01, CMR-04, DD-MN-01
#   - bootstrap-meta / file-meta:
#     - basename without extension, copied as-is
#     - example:
#         docs/AI_WORKFLOW_BOOTSTRAP.txt -> DOC_ID: AI_WORKFLOW_BOOTSTRAP
#
# - DOC_FILE is the repo-relative path as staged (forward slashes)
# - DOC_REV is computed as (commit-count touching file) + 1 when the file is staged with changes
# - DOC_GIT is the last commit hash that touched the file before this commit (0000000 for new files)
# - For bootstrap-meta and file-meta:
#   - existing DOC_STATUS is preserved if present
#   - if missing, DOC_STATUS: STABLE is added
#
# Safety / anti-footgun:
# - Refuses to run if a file has partially staged changes (staged + unstaged), because the hook edits and re-stages
#   the whole file and would destroy partial staging.
# - Refuses ambiguous/malformed metadata blocks (missing/duplicate markers, content after footer, etc.)
# - Refuses if required tools are missing
# - Enforces metadata structure and ordering; overwrites the metadata block content to match spec

set -euo pipefail
IFS=$'\n\t'

die() {
  echo "ERROR: $*" >&2
  exit 1
}

needCmd() {
  command -v "$1" >/dev/null 2>&1 || die "Missing required command: $1"
}

needCmd git

repoRoot="$(git rev-parse --show-toplevel 2>/dev/null)" || die "Not a git repository"
cd "$repoRoot"

PY_EXE="$repoRoot/python-embedded/python.exe"
if [ ! -f "$PY_EXE" ]; then
  die "Missing repo-local Python: $PY_EXE
Run setup.ps1 (from repo root) to install the embeddable runtime, then retry the commit."
fi

# Basic sanity check that it runs
if ! "$PY_EXE" -c "import sys; assert sys.version_info >= (3, 12)" >/dev/null 2>&1; then
  die "Repo-local Python exists but failed to run or is not Python 3.12+: $PY_EXE"
fi

isDocsFileWanted() {
  local f="$1"
  case "$f" in
    docs/*.md|docs/*.txt|docs/*.json5|docs/*/*.md|docs/*/*.txt|docs/*/*.json5|docs/*/*/*.md|docs/*/*/*.txt|docs/*/*/*.json5|docs/*/*/*/*.md|docs/*/*/*/*.txt|docs/*/*/*/*.json5|docs/*/*/*/*/*.md|docs/*/*/*/*/*.txt|docs/*/*/*/*/*.json5)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

# Extract DOC_ID from repo-relative path for doc-meta:
# - path must start with "docs/"
# - filename part is after last "/"
# - filename format: "<DOC_ID>_<normalized text>.<EXT>"
# - DOC_ID is before first "_"
# - DOC_ID regex: ^[A-Z]+(-[A-Z]+)*-[A-Z0-9]+$
extractDocIdFromPathOrDie() {
  local path="$1"

  [[ -n "$path" ]] || die "Path cannot be empty"
  [[ "$path" == docs/* ]] || die "Path must be under docs/: '$path'"

  local base="${path##*/}"
  [[ -n "$base" ]] || die "Filename cannot be empty: '$path'"

  # Must not be ".onlyextension" (no leading dot, must have at least one non-dot char before first dot)
  [[ "$base" != .* ]] || die "Filename must not start with '.': '$path'"

  # Must contain underscore (DOC_ID separator)
  [[ "$base" == *_* ]] || die "Filename must contain '_' after DOC_ID: '$path'"

  # Must contain at least one dot for extension
  [[ "$base" == *.* ]] || die "Filename must contain an extension (a '.'): '$path'"

  # First character must be [A-Z]
  [[ "${base:0:1}" =~ [A-Z] ]] || die "Filename must start with [A-Z]: '$path'"

  # Must contain '-' (per DOC_ID pattern)
  [[ "$base" == *-* ]] || die "Filename must contain '-' in DOC_ID: '$path'"

  local DOC_ID="${base%%_*}"
  [[ -n "$DOC_ID" ]] || die "DOC_ID extracted from filename is empty: '$path'"

  # Validate DOC_ID pattern:
  # - starts with one or more [A-Z]
  # - may contain additional "-[A-Z]+" segments
  # - ends with "-[A-Z0-9]+"
  if ! [[ "$DOC_ID" =~ ^[A-Z]+(-[A-Z]+)*-[A-Z0-9]+$ ]]; then
    die "Invalid DOC_ID '$DOC_ID' extracted from '$path'.
Expected pattern: starts with one or more [A-Z], may contain additional
'-[A-Z]+' segments, and must end with '-[A-Z0-9]+'."
  fi

  printf '%s' "$DOC_ID"
}

# Extract basename without extension for bootstrap-meta / file-meta.
extractBasenameWithoutExtensionOrDie() {
  local path="$1"

  [[ -n "$path" ]] || die "Path cannot be empty"
  [[ "$path" == docs/* ]] || die "Path must be under docs/: '$path'"

  local base="${path##*/}"
  [[ -n "$base" ]] || die "Filename cannot be empty: '$path'"
  [[ "$base" != .* ]] || die "Filename must not start with '.': '$path'"
  [[ "$base" == *.* ]] || die "Filename must contain an extension (a '.'): '$path'"

  local stem="${base%.*}"
  [[ -n "$stem" ]] || die "Basename without extension is empty: '$path'"

  printf '%s' "$stem"
}

# Read staged files under docs/ (NUL-delimited to handle spaces)
mapfile -d '' stagedFiles < <(git diff --cached --name-only -z --diff-filter=ACMR -- docs/)

if [ "${#stagedFiles[@]}" -eq 0 ]; then
  exit 0
fi

targets=()
for f in "${stagedFiles[@]}"; do
  if isDocsFileWanted "$f"; then
    targets+=("$f")
  fi
done

if [ "${#targets[@]}" -eq 0 ]; then
  exit 0
fi

# Guard: refuse partial staging for any target file (staged + unstaged)
for f in "${targets[@]}"; do
  [ -f "$f" ] || die "Staged path not found in working tree: $f"

  # If no staged changes, skip checks.
  if git diff --cached --quiet -- "$f"; then
    continue
  fi

  # If unstaged changes also exist, refuse.
  if ! git diff --quiet -- "$f"; then
    die "Partial staging detected for '$f'.
This hook edits and re-stages the whole file (would destroy partial staging).
Fix: stage the whole file (git add '$f') or stash/restore unstaged parts, then commit."
  fi
done

for f in "${targets[@]}"; do
  # Only update if the file has staged changes.
  if git diff --cached --quiet -- "$f"; then
    continue
  fi

  # Decide DOC_ID rule from metadata marker:
  # - doc-meta       -> strict DOC_ID extracted from filename prefix
  # - bootstrap-meta -> full basename without extension
  # - file-meta      -> full basename without extension
  if grep -Fqx -- '--- doc-meta ---' "$f"; then
    expectedDocId="$(extractDocIdFromPathOrDie "$f")"
  elif grep -Fqx -- '--- bootstrap-meta ---' "$f" || grep -Fqx -- '--- file-meta ---' "$f"; then
    expectedDocId="$(extractBasenameWithoutExtensionOrDie "$f")"
  else
    die "Missing supported metadata start marker in '$f'.
Expected one of:
  --- doc-meta ---
  --- bootstrap-meta ---
  --- file-meta ---"
  fi

  # DOC_FILE is the repo-relative path (forward slashes) exactly as staged
  expectedFile="$f"

  # Last hash touching the file BEFORE this commit (short). If none (new file), use 0000000.
  lastHash="$(git log -n 1 --follow --pretty=format:%h -- "$f" 2>/dev/null || true)"
  if [ -z "$lastHash" ]; then
    lastHash="0000000"
  fi

  # rev base = number of commits touching the file so far (before this commit). New file => 0.
  revBase="$(git log --follow --pretty=format:%H -- "$f" 2>/dev/null | wc -l | tr -d ' ')"
  newRev=$((revBase + 1))

  "$PY_EXE" - "$f" "$expectedDocId" "$expectedFile" "$newRev" "$lastHash" <<'PY'
import sys

path = sys.argv[1]
expected_doc_id = sys.argv[2]
expected_file = sys.argv[3]
new_rev = int(sys.argv[4])
new_hash = sys.argv[5]

doc_start_marker = "--- doc-meta ---"
bootstrap_start_marker = "--- bootstrap-meta ---"
file_start_marker = "--- file-meta ---"

doc_end_marker = "----------------"
bootstrap_end_marker = "----------------------"
file_end_marker = "-----------------"

with open(path, "r", encoding="utf-8", newline="") as f:
  text = f.read()

# Preserve newline style where possible
newline = "\n"
if "\r\n" in text and "\n" in text:
  newline = "\r\n"

lines = text.replace("\r\n", "\n").split("\n")

doc_starts = [i for i, line in enumerate(lines) if line == doc_start_marker]
bootstrap_starts = [i for i, line in enumerate(lines) if line == bootstrap_start_marker]
file_starts = [i for i, line in enumerate(lines) if line == file_start_marker]

total_starts = len(doc_starts) + len(bootstrap_starts) + len(file_starts)
if total_starts != 1:
  raise SystemExit(
    f"ERROR: {path}: expected exactly one metadata start marker "
    f"('{doc_start_marker}', '{bootstrap_start_marker}', or '{file_start_marker}'), "
    f"found {total_starts}"
  )

if doc_starts:
  start_marker = doc_start_marker
  end_marker = doc_end_marker
  s = doc_starts[0]
  meta_kind = "doc"
elif bootstrap_starts:
  start_marker = bootstrap_start_marker
  end_marker = bootstrap_end_marker
  s = bootstrap_starts[0]
  meta_kind = "bootstrap"
else:
  start_marker = file_start_marker
  end_marker = file_end_marker
  s = file_starts[0]
  meta_kind = "file"

# Find correct end marker after start
try:
  e = next(i for i in range(s + 1, len(lines)) if lines[i] == end_marker)
except StopIteration:
  raise SystemExit(f"ERROR: {path}: missing end marker '{end_marker}' after metadata start")

# Metadata block must be at end of document. Allow only trailing empty lines after end marker.
tail = lines[e + 1 :]
if any(line.strip() != "" for line in tail):
  raise SystemExit(
    f"ERROR: {path}: metadata block must be at the end of the document; "
    f"found content after '{end_marker}'"
  )

# Parse existing metadata lines between markers
existing_block_lines = lines[s + 1 : e]
existing_fields: dict[str, str] = {}

for line in existing_block_lines:
  stripped = line.strip()
  if not stripped:
    continue
  if ":" not in line:
    raise SystemExit(
      f"ERROR: {path}: malformed metadata line inside '{start_marker}': '{line}'"
    )
  key, value = line.split(":", 1)
  key = key.strip()
  value = value.lstrip()
  if not key:
    raise SystemExit(
      f"ERROR: {path}: malformed metadata line inside '{start_marker}': '{line}'"
    )
  existing_fields[key] = value

# Build canonical block.
# doc:
#   DOC_ID, DOC_FILE, DOC_REV, DOC_GIT
#
# bootstrap/file:
#   DOC_ID, DOC_FILE, DOC_REV, DOC_GIT, DOC_STATUS
#   preserve existing DOC_STATUS if present, otherwise default to STABLE
block = [
  f"DOC_ID: {expected_doc_id}",
  f"DOC_FILE: {expected_file}",
  f"DOC_REV: {new_rev}",
  f"DOC_GIT: {new_hash}",
]

if meta_kind in {"bootstrap", "file"}:
  doc_status = existing_fields.get("DOC_STATUS", "STABLE")
  block.append(f"DOC_STATUS: {doc_status}")

# Enforce line length rule:
# - Only the value of the "DOC_FILE:" field MAY exceed 79 characters.
# - No other metadata line may exceed 79 characters.
def check_len(line: str, is_file: bool) -> None:
  if is_file:
    return
  if len(line) > 79:
    raise SystemExit(f"ERROR: {path}: metadata line exceeds 79 chars: '{line}'")

check_len(block[0], is_file=False)  # DOC_ID
check_len(block[1], is_file=True)   # DOC_FILE
check_len(block[2], is_file=False)  # DOC_REV
check_len(block[3], is_file=False)  # DOC_GIT
if meta_kind in {"bootstrap", "file"}:
  check_len(block[4], is_file=False)  # DOC_STATUS

# Replace the existing block content with the canonical block.
new_lines = lines[: s + 1] + block + [end_marker]

# Preserve a single trailing newline if the original file had one.
had_trailing_newline = text.endswith("\n") or text.endswith("\r\n")
new_text = newline.join(new_lines)
if had_trailing_newline:
  new_text += newline

with open(path, "w", encoding="utf-8", newline="") as f:
  f.write(new_text)
PY

  git add -- "$f"
done

exit 0
